{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AegisPolicy",
  "description": "Defines resource constraints and metadata for an agent session",
  "type": "object",
  "required": ["policy_id", "version", "constraints"],
  "properties": {
    "policy_id": {
      "type": "string",
      "description": "Unique identifier for this policy version"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["resource_id", "action", "allowed"],
        "properties": {
          "resource_id": { "type": "string" },
          "action": { "type": "string", "example": "READ" },
          "allowed": { "type": "boolean" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Arbitrary key-value pairs for policy context"
    }
  }
}