{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BFT Clock Daemon Config",
  "type": "object",
  "required": ["data_dir", "grpc_addr"],
  "properties": {
    "data_dir": {
      "type": "string"
    },
    "grpc_addr": {
      "type": "string",
      "pattern": "^.+:[0-9]+$"
    },
    "insecure_dev": {
      "type": "boolean"
    },
    "min_quorum": {
      "type": "integer",
      "minimum": 1
    },
    "authorities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}