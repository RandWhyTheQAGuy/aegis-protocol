{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Error Response",
  "type": "object",
  "required": ["status", "message"],
  "properties": {
    "status": {
      "type": "string",
      "const": "error"
    },
    "message": {
      "type": "string"
    },
    "code": {
      "type": "string"
    },
    "retryable": {
      "type": "boolean"
    }
  }
}