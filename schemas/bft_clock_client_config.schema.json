{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BftClockClientConfig",
  "type": "object",
  "required": ["daemon_pubkey_hex"],
  "additionalProperties": false,
  "properties": {
    "socket_path": {
      "type": "string"
    },
    "pipe_name": {
      "type": "string"
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "daemon_pubkey_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "ipc_hmac_key_hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "max_skew_s": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60
    },
    "connect_timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "recv_timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "cache_ttl_ms": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10000
    },
    "backoff_initial_ms": {
      "type": "integer",
      "minimum": 1
    },
    "backoff_max_ms": {
      "type": "integer",
      "minimum": 1
    },
    "fail_closed": {
      "type": "boolean"
    },
    "expected_socket_uid": {
      "type": "integer"
    },
    "nonce_window": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100000
    }
  }
}