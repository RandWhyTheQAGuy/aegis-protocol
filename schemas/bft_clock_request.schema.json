{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BFT Clock Request",
  "type": "object",
  "required": ["cmd", "nonce", "client_id", "req_at"],
  "properties": {
    "cmd": {
      "type": "string",
      "const": "time_request"
    },
    "nonce": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "client_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "req_at": {
      "type": "integer"
    },
    "mac": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    }
  },
  "additionalProperties": false
}