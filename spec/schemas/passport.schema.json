{
  "model_id":              string,   // Unique identifier for the agent/model
  "model_version":         string,   // Semantic version (e.g., "1.0.2")
  "capabilities": {
    "classifier_authority":   bool,  // Allowed to provide authority scores
    "classifier_sensitivity": bool,  // Allowed to provide sensitivity scores
    "bft_consensus":          bool,  // Participant in BFT consensus rounds
    "entropy_flush":          bool   // Capable of local state purging
  },
  "policy_hash":           string,   // SHA-256 of the policy the agent must follow
  "issued_at":             uint64,   // Unix timestamp of issuance
  "expires_at":            uint64,   // Expiry timestamp (Registry rejection point)
  "signing_key_id":        uint32,   // Version of the Registry key used to sign
  "signature":             string,   // HMAC-SHA256 hex signature of the passport body
  "recovery_token":        string?   // Optional: Set if issued via recovery protocol
}