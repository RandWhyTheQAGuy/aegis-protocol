{
  "entry_id":             string,   // Unique identifier for this entry (hash of sequence)
  "prev_hash":            string,   // SHA-256 hash of the preceding entry ("GENESIS" for entry 0)
  "sequence":             uint64,   // Monotonic counter (0-indexed)
  "timestamp":            uint64,   // Unix timestamp of the event
  "event_type":           string,   // Type of event (e.g., "PAYLOAD", "STATE_CHANGE")
  "session_id":           string,   // ID of the session this event belongs to
  "agent_id":             string,   // ID of the agent performing the action
  "payload_hash":         string,   // SHA-256 of the data associated with this event
  "detail":               string,   // JSON-encoded string containing event-specific metadata
  "entry_hash":           string    // SHA-256 hash of all fields (canonicalized)
}