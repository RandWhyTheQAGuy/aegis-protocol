Message 1 -- HELLO (initiator -> responder)
  {
    "type":             "UML001_HELLO",
    "passport":         <SemanticPassport>,
    "session_nonce":    string,   // 32-byte random hex, generated by initiator
    "proposed_schema":  string    // schema version for this session's payloads
  }

  Message 2 -- HELLO_ACK (responder -> initiator)
  {
    "type":             "UML001_HELLO_ACK",
    "passport":         <SemanticPassport>,
    "session_nonce":    string,   // echo initiator nonce + append own 32-byte nonce
    "accepted_schema":  string,   // must match or be a supported subset
    "session_id":       string    // SHA-256(initiator_nonce + responder_nonce)
  }

  Message 3 -- HELLO_CONFIRM (initiator -> responder)
  {
    "type":             "UML001_HELLO_CONFIRM",
    "session_id":       string,   // must match Message 2
    "signature":        string    // HMAC-SHA256(session_id, initiator_passport_key)
  }
