{
  "schema_version":        string,   // Protocol version (e.g., "uml001-v1")
  "initiator_nonce":       string,   // 32-byte hex entropy
  "initiator_passport":    object,   // The full Semantic Passport object
  "initiator_ephemeral_pub": string, // Ephemeral X25519 public key (hex)
  "transport_binding":     string    // ID binding (e.g., "NONE" or IP:Port)
},
{
  "responder_nonce":       string,   // 32-byte hex entropy
  "responder_passport":    object,   // The full Semantic Passport object
  "responder_ephemeral_pub": string, // Ephemeral X25519 public key (hex)
  "signature":             string    // HMAC over nonces + keys
}