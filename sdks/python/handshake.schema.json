{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aegis-protocol.dev/schemas/handshake.schema.json",
  "title": "HandshakeMessages",
  "description": "Schema definitions for all three messages in the UML-001 capability negotiation handshake.",
  "definitions": {
    "Hello": {
      "type": "object",
      "required": ["type", "passport", "session_nonce", "proposed_schema"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "UML001_HELLO" },
        "passport": { "$ref": "passport.schema.json" },
        "session_nonce": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "32-byte random hex nonce generated by the initiator."
        },
        "proposed_schema": {
          "type": "string",
          "minLength": 1,
          "description": "Payload schema version the initiator proposes for this session."
        }
      }
    },
    "HelloAck": {
      "type": "object",
      "required": ["type", "passport", "session_nonce", "accepted_schema", "session_id"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "UML001_HELLO_ACK" },
        "passport": { "$ref": "passport.schema.json" },
        "session_nonce": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$",
          "description": "Initiator nonce concatenated with responder's 32-byte nonce (64 hex chars each = 128 total)."
        },
        "accepted_schema": {
          "type": "string",
          "minLength": 1,
          "description": "Schema version accepted for this session. Must match or be a supported subset of proposed_schema."
        },
        "session_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256(initiator_nonce + responder_nonce). Serves as the session identifier."
        }
      }
    },
    "HelloConfirm": {
      "type": "object",
      "required": ["type", "session_id", "signature"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "UML001_HELLO_CONFIRM" },
        "session_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "Must match the session_id from HelloAck."
        },
        "signature": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "HMAC-SHA256(session_id, initiator_registry_key)."
        }
      }
    },
    "HelloReject": {
      "type": "object",
      "required": ["type", "reason"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "UML001_HELLO_REJECT" },
        "reason": {
          "type": "string",
          "enum": [
            "REJECT_PASSPORT_INVALID",
            "REJECT_PASSPORT_EXPIRED",
            "REJECT_REGISTRY_MISMATCH",
            "REJECT_SCHEMA_MISMATCH",
            "REJECT_POLICY_MISMATCH",
            "REJECT_RECOVERY_REQUIRED"
          ]
        },
        "detail": {
          "type": "string",
          "description": "Optional human-readable detail for logging purposes."
        }
      }
    }
  }
}
